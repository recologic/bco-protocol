# BCO Protocol — Environment Configuration
# Copy to .env and fill in your values

# Deployer private key (hex, without 0x prefix) — for testnet only
PRIVATE_KEY=your_private_key_here

# Treasury address (TRON base58 format, starts with T)
TREASURY_ADDRESS=TYourTreasuryAddressHere

# Pauser address (TRON base58, can be same as deployer for testing)
PAUSER_ADDRESS=TYourPauserAddressHere

# Admin transfer delay in seconds (0 for testing, 172800 = 48h for production)
ADMIN_TRANSFER_DELAY=0

# Reward duration in seconds (7776000 = 90 days)
REWARD_DURATION=7776000

# Timelock delay in seconds (60 for testing, 259200 = 72h for production)
TIMELOCK_DELAY=60

# Feee.io energy API (for mainnet deployment)
FEEE_API_KEY=your_feee_api_key
FEEE_USER_AGENT=your_feee_user_agent

# TRON nodes
TRON_FULL_NODE=https://nile.trongrid.io
TRON_SOLIDITY_NODE=https://nile.trongrid.io
